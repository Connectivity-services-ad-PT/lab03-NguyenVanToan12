              { "key": "Prefer", "value": "example=fire_alert" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts/ALT-001",
              "host": ["{{baseUrl}}"],
              "path": ["alerts", "ALT-001"]
            },
            "description": "Kiểm chứng đa hình (Polymorphism) qua Discriminator. ALT-001 là mẫu FireAlert."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is a FireAlert', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('alertType', 'FIRE');",
                  "  pm.expect(json).to.have.property('location', 'LAB-401');",
                  "  pm.expect(json).to.have.property('temperature');",
                  "  pm.expect(json.temperature).to.be.a('number');",
                  "});"
                ]
              }
