    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /alerts/recent - Authorized request accepted",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts/recent?limit=1",
              "host": ["{{baseUrl}}"],
              "path": ["alerts", "recent"],
              "query": [
                { "key": "limit", "value": "1" }
              ]
            },
            "description": "Xác nhận request có token hợp lệ được chấp nhận."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Authorized request returns 200', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /alerts - Missing token rejected on local service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceService\": \"core-business\",\n  \"alertType\": \"UNAUTHORIZED_ACCESS\",\n  \"severity\": \"HIGH\",\n  \"message\": \"Thieu token\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Auth test thật: thiếu token. Khi chạy ở mock, test được skip có kiểm soát vì Prism không có middleware auth."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /alerts - Invalid token rejected on local service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-jwt-token" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceService\": \"core-business\",\n  \"alertType\": \"UNAUTHORIZED_ACCESS\",\n  \"severity\": \"HIGH\",\n  \"message\": \"Sai token\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Auth test thật: token không hợp lệ."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not validate auth signature', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "POST /alerts - Missing required fields returns validation error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceService\": \"core-business\",\n  \"severity\": \"HIGH\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Kiểm tra lỗi validate khi thiếu trường bắt buộc."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Missing required fields returns 400 client error', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Error response follows ProblemDetails schema', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('type');",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json).to.have.property('detail');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /alerts - Invalid enum value for severity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
