            "url": {
              "raw": "{{baseUrl}}/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceService\": \"core-business\",\n  \"alertType\": \"UNAUTHORIZED_ACCESS\",\n  \"severity\": \"CRITICAL\",\n  \"message\": \"Phat hien xam nhap\",\n  \"relatedEventId\": \"evt_0196fb3d-7ad7-7d1e-9f49-5d5148d2bcba\"\n}",
              "options": {
                "raw": { "language": "json" }
